{
    "name": "klan1/k1lib-app-skeleton",
    "description": "App skeleton using k1.lib.",
    "license": "Apache-2.0",
    "type": "application",
    "version": "3.0.0",
    "homepage": "https://github.com/klan1/k1.app-skeleton",
    "authors": [
        {
            "name": "Alejandro Trujillo J. (J0hnd03)",
            "homepage": "https://github.com/j0hnd03"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "klan1/k1.lib": "dev-master",
        "phpmailer/phpmailer": "v6.x",
        "klan1/k1app-template-mazer": "dev-master"
    },
    "scripts": {
        "docker:up": "cd docker && docker compose up -d"
    },
    "autoload": {
        "psr-4": {
            "k1app\\core\\": "src/classes/k1app/core/",
            "k1app\\table_config\\": "src/classes/k1app/table_config/",
            "k1app\\": "src/classes/k1app/controllers/"
        }
    }
}
